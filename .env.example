# Copy to .env for local development, and set these in the Vercel dashboard for prod.

# Flask session-cookie signing key. Generate a strong random value:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# PostgreSQL connection string (Neon / Supabase / local).
#   local example:  postgresql://localhost:5432/yourfuture
#   Neon example:   postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://localhost:5432/yourfuture

# Set to "production" on Vercel. Enables Secure cookies and disables dev CORS.
FLASK_ENV=development

# Local-only: origin allowed to call the API cross-origin (Vite dev server).
DEV_FRONTEND_ORIGIN=http://localhost:5173

# Used only by seed.py to create the initial admin account.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Frontend (Vite) — only needed for split-domain deploys. Same-origin Vercel
# deploys can leave this unset (defaults to "/api").
# VITE_API_URL=https://your-api-host/api
